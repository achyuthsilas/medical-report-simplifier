# Copy to .env and fill in real values

# JWT secret - generate a strong random string for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-this-with-a-long-random-string-in-production

# Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (default uses SQLite file)
DATABASE_URL=sqlite:///./medical_reports.db

# Groq API (used in Phase 3)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
